"""Conjure images via ChatGPT or Gemini browser automation."""

import argparse
import sys
import re
import time
import base64
from pathlib import Path
from datetime import datetime

try:
    from playwright.sync_api import TimeoutError as PlaywrightTimeout
    from cloakbrowser import launch_persistent_context as cloak_launch
except ImportError as exc:
    PlaywrightTimeout = TimeoutError
    cloak_launch = None
    IMPORT_ERROR = exc
else:
    IMPORT_ERROR = None

CONFIG_DIR = Path.home() / ".config" / "conjure"

SERVICES = {
    "chatgpt": {
        "url": "https://chatgpt.com/",
        "profile": CONFIG_DIR / "chatgpt-profile",
        "input_sel": "#prompt-textarea",
        "send_sel": 'button[data-testid="send-button"]',
        "new_chat_sels": [
            'a[data-testid="create-new-chat-button"]',
            'a:has-text("New chat")',
        ],
        "stop_sels": [
            'button[aria-label="Stop generating"]',
            'button[data-testid="stop-button"]',
        ],
        "login_sels": 'button:has-text("Log in"), a:has-text("Log in"), button:has-text("Sign up"), a:has-text("Sign up")',
        "prompt_prefix": "Generate an image: ",
        "edit_prefix": "Edit this image: ",
        "upload": lambda page, path: page.locator("input#upload-photos").set_input_files(str(path)),
    },
    "gemini": {
        "url": "https://gemini.google.com/app",
        "profile": CONFIG_DIR / "gemini-profile",
        "input_sel": ".ql-editor",
        "send_sel": 'button[aria-label="Send message"]',
        "new_chat_sels": [
            'a[aria-label="New chat"]',
            'a[href="/app"][aria-label="New chat"]',
        ],
        "stop_sels": [
            'button[aria-label="Stop response"]',
        ],
        "response_sel": "message-content",
        "login_sels": 'a:has-text("Sign in"), button:has-text("Sign in")',
        "prompt_prefix": "Generate an image of ",
        "edit_prefix": "Edit this image: ",
        "upload": lambda page, path: _gemini_upload(page, path),
    },
}


# ── Shared utilities ──────────────────────────────────────────────


def _gemini_upload(page, path):
    page.locator(".upload-card-button").click()
    time.sleep(1)
    with page.expect_file_chooser() as fc_info:
        page.locator('button[data-test-id="local-images-files-uploader-button"]').click()
    fc_info.value.set_files(str(path))


def slugify(text: str, max_len: int = 40) -> str:
    s = re.sub(r"[^\w\s-]", "", text.lower())
    s = re.sub(r"[-\s]+", "-", s).strip("-")
    return s[:max_len].rstrip("-")


def get_page_image_srcs(page) -> set:
    srcs = set()
    for img in page.locator("img").all():
        try:
            src = img.get_attribute("src")
            if src:
                srcs.add(src)
        except Exception:
            pass
    return srcs


def require_runtime_dependencies():
    if cloak_launch is not None:
        return
    print("Dependencies missing. Run setup first:")
    print("  cd conjure && ./setup")
    if IMPORT_ERROR:
        print(f"Import error: {IMPORT_ERROR}")
    sys.exit(1)


def launch_browser(profile_dir, headless=True):
    require_runtime_dependencies()
    profile_dir.mkdir(parents=True, exist_ok=True)
    ctx = cloak_launch(
        str(profile_dir),
        headless=headless,
        viewport={"width": 1280, "height": 900},
        args=["--ozone-platform=x11"],
    )
    page = ctx.pages[0] if ctx.pages else ctx.new_page()
    return ctx, page


def is_logged_in(page, svc):
    login_btns = page.locator(svc["login_sels"])
    return login_btns.count() == 0


def ensure_logged_in(page, svc, headless=True):
    try:
        page.wait_for_selector(svc["input_sel"], timeout=15000)
    except PlaywrightTimeout:
        pass

    if not is_logged_in(page, svc):
        if headless:
            print("Not logged in. Run 'conjure --login' first.")
            sys.exit(1)
        print("Not logged in. Please log in in the browser window...")
        deadline = time.time() + 300
        while time.time() < deadline:
            if is_logged_in(page, svc):
                print("Logged in!")
                time.sleep(2)
                try:
                    page.wait_for_selector(svc["input_sel"], timeout=30000)
                except PlaywrightTimeout:
                    pass
                return
            time.sleep(1)
        print("Login timed out.")
        sys.exit(1)


def get_prompt_text(page, svc):
    field = page.locator(svc["input_sel"])
    try:
        return field.input_value()
    except Exception:
        pass
    try:
        return field.inner_text()
    except Exception:
        return ""


def get_page_state(page, svc):
    state = {
        "url": page.url,
        "user_turns": page.locator('[data-turn="user"]').count(),
        "response_nodes": 0,
        "image_srcs": get_page_image_srcs(page),
        "prompt_text": get_prompt_text(page, svc),
    }
    response_sel = svc.get("response_sel")
    if response_sel:
        try:
            state["response_nodes"] = page.locator(response_sel).count()
        except Exception:
            pass
    return state


def has_conversation_history(page, svc):
    try:
        if page.locator('[data-turn="user"]').count() > 0:
            return True
    except Exception:
        pass

    response_sel = svc.get("response_sel")
    if response_sel:
        try:
            if page.locator(response_sel).count() > 0:
                return True
        except Exception:
            pass

    return False


def wait_for_clean_chat(page, svc, timeout=20):
    deadline = time.time() + timeout

    while time.time() < deadline:
        try:
            page.wait_for_selector(svc["input_sel"], timeout=2000)
        except PlaywrightTimeout:
            pass

        if not has_conversation_history(page, svc):
            return True

        time.sleep(1)

    return False


def ensure_fresh_chat(page, svc):
    if wait_for_clean_chat(page, svc, timeout=3):
        return

    for sel in svc.get("new_chat_sels", []):
        try:
            button = page.locator(sel).first
            if button.count() == 0 or not button.is_visible():
                continue
            button.click()
            if wait_for_clean_chat(page, svc):
                return
        except Exception:
            continue

    # Fall back to reloading the service root once more in case the UI did not
    # expose a fresh-chat control immediately.
    try:
        page.goto(svc["url"])
    except Exception:
        return
    wait_for_clean_chat(page, svc)


def wait_for_send_confirmation(page, svc, baseline, timeout=30):
    deadline = time.time() + timeout
    response_sel = svc.get("response_sel")

    while time.time() < deadline:
        try:
            if page.locator('[data-turn="user"]').count() > baseline["user_turns"]:
                return True
        except Exception:
            pass

        if response_sel:
            try:
                if page.locator(response_sel).count() > baseline["response_nodes"]:
                    return True
            except Exception:
                pass

        try:
            prompt_text = get_prompt_text(page, svc)
            if baseline["prompt_text"].strip() and not prompt_text.strip():
                return True
        except Exception:
            pass

        if page.url != baseline["url"] and "/c/" in page.url:
            return True

        time.sleep(1)

    return False


def wait_response_done(page, svc, timeout=180):
    time.sleep(3)
    deadline = time.time() + timeout
    response_sel = svc.get("response_sel")
    last_content = ""
    stable_since = None

    while time.time() < deadline:
        # Stop button detection
        generating = any(
            page.locator(sel).count() > 0 for sel in svc["stop_sels"]
        )
        if not generating:
            time.sleep(2)
            still = any(
                page.locator(sel).count() > 0 for sel in svc["stop_sels"]
            )
            if not still:
                return True

        # Gemini: content stability fallback (stop button lingers)
        if response_sel:
            try:
                els = page.locator(response_sel)
                if els.count() > 0:
                    content = els.last.evaluate("el => el.innerHTML")
                    if content and content == last_content:
                        if stable_since is None:
                            stable_since = time.time()
                        elif time.time() - stable_since >= 8:
                            return True
                    else:
                        last_content = content
                        stable_since = None
            except Exception:
                pass

        time.sleep(1)
    return False


def _is_ai_response_image(img):
    """Check if an image is inside the AI's response (not the user's message
    or the composer). On ChatGPT, requires data-turn='assistant'. On Gemini
    (no data-turn), accepts images inside 'message-content' elements."""
    try:
        return img.evaluate("""el => {
            let p = el;
            let foundTurn = false;
            while (p) {
                if (p.dataset && p.dataset.turn === 'user') return false;
                if (p.dataset && p.dataset.turn === 'assistant') return true;
                if (p.tagName === 'MESSAGE-CONTENT') return true;
                p = p.parentElement;
            }
            return false;
        }""")
    except Exception:
        return False


def wait_for_images(page, before_srcs, timeout=300):
    """Wait until at least one new high-res AI-generated image appears."""
    deadline = time.time() + timeout

    while time.time() < deadline:
        page.evaluate("window.scrollTo(0, document.body.scrollHeight)")
        for img in page.locator("img").all():
            try:
                src = img.get_attribute("src") or ""
                if src in before_srcs or src.startswith("data:image/svg"):
                    continue
                natural_w = img.evaluate("el => el.naturalWidth")
                if natural_w >= 512 and _is_ai_response_image(img):
                    time.sleep(5)
                    return True
            except Exception:
                continue
        time.sleep(2)

    return False


def save_image_via_download_gemini(page, img_element, filepath):
    """Hover over image and click the native download button (Gemini)."""
    try:
        img_element.hover()
        time.sleep(1)
        btn = page.locator('button[aria-label="Download full size image"]')
        if btn.count() == 0 or not btn.is_visible():
            return False
        with page.expect_download(timeout=30000) as dl_info:
            btn.click()
        dl = dl_info.value
        dl.save_as(str(filepath))
        if filepath.stat().st_size > 1024:
            return True
        filepath.unlink(missing_ok=True)
    except Exception:
        pass
    return False


def save_image_via_download_chatgpt(page, img_element, filepath):
    """Click image to open modal, then click Save to download (ChatGPT)."""
    try:
        img_element.click()
        time.sleep(2)
        save_btn = page.locator('button:has-text("Save")').first
        if not save_btn.is_visible():
            page.keyboard.press("Escape")
            return False
        with page.expect_download(timeout=30000) as dl_info:
            save_btn.click()
        dl = dl_info.value
        dl.save_as(str(filepath))
        # Close the modal
        time.sleep(1)
        close = page.locator('button:has-text("Close")')
        if close.count() > 0 and close.first.is_visible():
            close.first.click()
        else:
            page.keyboard.press("Escape")
        if filepath.stat().st_size > 1024:
            return True
        filepath.unlink(missing_ok=True)
    except Exception:
        # Close modal on failure
        try:
            page.keyboard.press("Escape")
        except Exception:
            pass
    return False


def save_image_via_fetch(page, img_element, filepath):
    """Fetch the image src through the browser (includes session cookies)."""
    src = img_element.get_attribute("src") or ""
    try:
        b64 = page.evaluate("""async (src) => {
            const resp = await fetch(src);
            const blob = await resp.blob();
            return new Promise((resolve) => {
                const reader = new FileReader();
                reader.onloadend = () => resolve(reader.result.split(',')[1]);
                reader.readAsDataURL(blob);
            });
        }""", src)
        filepath.write_bytes(base64.b64decode(b64))
        if filepath.stat().st_size > 1024:
            return True
        filepath.unlink(missing_ok=True)
    except Exception:
        pass

    # Canvas fallback
    try:
        b64 = img_element.evaluate("""el => {
            const canvas = document.createElement('canvas');
            canvas.width = el.naturalWidth;
            canvas.height = el.naturalHeight;
            canvas.getContext('2d').drawImage(el, 0, 0);
            return canvas.toDataURL('image/png').split(',')[1];
        }""")
        filepath.write_bytes(base64.b64decode(b64))
        if filepath.stat().st_size > 1024:
            return True
        filepath.unlink(missing_ok=True)
    except Exception:
        pass

    return False


def save_image(page, img_element, filepath, service_name):
    if service_name == "chatgpt":
        if save_image_via_download_chatgpt(page, img_element, filepath):
            return True
    elif service_name == "gemini":
        if save_image_via_download_gemini(page, img_element, filepath):
            return True
    return save_image_via_fetch(page, img_element, filepath)


def find_best_image(page, before_srcs):
    """Find the best new large image on the page."""
    page.evaluate("window.scrollTo(0, document.body.scrollHeight)")
    time.sleep(1)
    candidates = []
    for img in page.locator("img").all():
        try:
            src = img.get_attribute("src") or ""
            if src in before_srcs or src.startswith("data:image/svg"):
                continue
            natural_w = img.evaluate("el => el.naturalWidth")
            if natural_w < 512:
                continue
            if not _is_ai_response_image(img):
                continue
            candidates.append((img, src, natural_w))
        except Exception:
            continue

    if not candidates:
        return None

    # Dedup by src — keep the element with the highest naturalWidth per URL
    best_by_src = {}
    for img, src, nw in candidates:
        if src not in best_by_src or nw > best_by_src[src][1]:
            best_by_src[src] = (img, nw)

    if not best_by_src:
        return None

    return max(best_by_src.values(), key=lambda x: x[1])[0]


# ── Commands ──────────────────────────────────────────────────────


def do_login(service_name):
    svc = SERVICES[service_name]
    print(f"Opening {service_name} for login...")
    ctx, page = launch_browser(svc["profile"], headless=False)
    try:
        page.goto(svc["url"])
        ensure_logged_in(page, svc, headless=False)
        print(f"Session saved for {service_name}.")
    except KeyboardInterrupt:
        print("\nCancelled.")
    finally:
        try:
            ctx.close()
        except Exception:
            pass


def do_generate(service_name, prompt, edit_image=None):
    svc = SERVICES[service_name]
    output_dir = Path.cwd()

    if edit_image:
        print(f"Editing ({service_name}): {edit_image.name} — {prompt}")
    else:
        print(f"Generating ({service_name}): {prompt}")

    ctx, page = launch_browser(svc["profile"])

    try:
        page.goto(svc["url"])
        ensure_logged_in(page, svc)
        ensure_fresh_chat(page, svc)

        page.wait_for_selector(svc["input_sel"], timeout=15000)

        # Upload image if editing
        if edit_image:
            svc["upload"](page, edit_image)
            # Wait for upload preview to appear (not a fixed delay)
            try:
                page.locator('img[src*="blob:"]').first.wait_for(timeout=30000)
            except PlaywrightTimeout:
                pass
            time.sleep(1)

        # Type prompt
        textarea = page.locator(svc["input_sel"])
        textarea.click()
        time.sleep(0.3)

        prefix = svc["edit_prefix"] if edit_image else svc["prompt_prefix"]
        full_prompt = prefix + prompt
        try:
            textarea.fill(full_prompt)
        except Exception:
            page.keyboard.type(full_prompt, delay=10)

        time.sleep(0.5)
        baseline = get_page_state(page, svc)

        # Submit — wait for send button to be ready, then verify it went through
        send = page.locator(svc["send_sel"])
        try:
            send.wait_for(state="visible", timeout=10000)
        except PlaywrightTimeout:
            pass
        time.sleep(1)

        if send.count() > 0 and send.is_enabled():
            send.click()
        else:
            page.keyboard.press("Enter")

        # Verify message was sent relative to the pre-submit page state
        sent = wait_for_send_confirmation(page, svc, baseline)
        if not sent:
            # Retry send
            send = page.locator(svc["send_sel"])
            if send.count() > 0 and send.is_enabled():
                send.click()
            else:
                page.keyboard.press("Enter")
            time.sleep(10)
            sent = True  # best effort

        before_srcs = baseline["image_srcs"]

        print("Waiting for image generation (this can take a minute)...")

        if not wait_response_done(page, svc, timeout=180):
            print("Warning: timed out waiting for response.")

        print("Waiting for image to finish rendering...")
        if not wait_for_images(page, before_srcs):
            print("Warning: images may not be fully rendered.")

        # Find and save the best image
        timestamp = datetime.now().strftime("%Y%m%d-%H%M%S")
        slug = slugify(prompt)
        filename = f"{slug}-{timestamp}.png"
        filepath = output_dir / filename

        best = find_best_image(page, before_srcs)
        if not best:
            # Retry — image may still be loading
            for _ in range(3):
                time.sleep(10)
                best = find_best_image(page, before_srcs)
                if best:
                    break

        if best and save_image(page, best, filepath, service_name):
            print(f"Saved: {filepath}")
        else:
            debug = output_dir / f"{slug}-{timestamp}-debug.png"
            page.screenshot(path=str(debug), full_page=True)
            print(f"No image found in response. Debug screenshot: {debug}")

    except KeyboardInterrupt:
        print("\nCancelled.")
    finally:
        try:
            ctx.close()
        except Exception:
            pass


# ── CLI ───────────────────────────────────────────────────────────


def build_parser():
    parser = argparse.ArgumentParser(
        prog="conjure",
        description="Generate and edit images via ChatGPT and Gemini",
        epilog=(
            "Examples:\n"
            '  conjure "a cat in a top hat"\n'
            '  conjure --gemini "a red panda"\n'
            '  conjure --edit img.png "add sunset"\n'
            '  conjure --gemini --edit img.png "make it night"\n'
            "  conjure --login gemini\n\n"
            "Each run starts from a fresh chat before sending the prompt."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    service = parser.add_mutually_exclusive_group()
    service.add_argument(
        "--chatgpt",
        dest="service",
        action="store_const",
        const="chatgpt",
        help="use ChatGPT (default)",
    )
    service.add_argument(
        "--gemini",
        dest="service",
        action="store_const",
        const="gemini",
        help="use Gemini",
    )
    parser.set_defaults(service="chatgpt")
    parser.add_argument(
        "--edit",
        metavar="IMAGE",
        type=Path,
        help="upload an image and edit it",
    )
    parser.add_argument(
        "--login",
        nargs="?",
        const="",
        metavar="SERVICE",
        help="open a browser to log in and save the session",
    )
    parser.add_argument(
        "prompt",
        nargs="*",
        help="image prompt",
    )
    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    if args.login is not None:
        service = args.login or args.service
        if service not in SERVICES:
            parser.error(f"unknown service: {service}. Use: chatgpt or gemini")
        do_login(service)
        return

    edit_image = None
    if args.edit is not None:
        edit_image = args.edit.resolve()
        if not edit_image.is_file():
            parser.error(f"file not found: {edit_image}")

    prompt = " ".join(args.prompt).strip()
    if not prompt:
        parser.error('the prompt is required unless "--login" is used')

    do_generate(args.service, prompt, edit_image=edit_image)


if __name__ == "__main__":
    main()
