#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"

echo "Creating virtual environment..."
python3 -m venv "$VENV_DIR"

echo "Installing dependencies..."
"$VENV_DIR/bin/pip" install playwright cloakbrowser
"$VENV_DIR/bin/playwright" install chromium

# Make conjure command available globally
mkdir -p ~/.local/bin
ln -sf "$SCRIPT_DIR/conjure" ~/.local/bin/conjure

echo ""
echo "Done! Usage:"
echo '  conjure "a cat wearing a top hat"'
echo ""
echo "First run: log in with 'conjure --login chatgpt' or 'conjure --login gemini'."

# Check if ~/.local/bin is in PATH
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    echo ""
    echo "Note: ~/.local/bin is not in your PATH. Add it:"
    echo '  export PATH="$HOME/.local/bin:$PATH"'
fi
